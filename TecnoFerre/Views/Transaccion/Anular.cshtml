@model TecnoFerre.Models.Transaccion

@{
    ViewData["Title"] = "Anular Transacción";
}

<h1>Anular Transacción</h1>

<h4>¿Está seguro de que desea anular esta transacción?</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <dl class="row">
            <dt class="col-sm-2">
                Usuario
            </dt>
            <dd class="col-sm-10">
                @Model.Usuario.Nombre
            </dd>
            <dt class="col-sm-2">
                Producto
            </dt>
            <dd class="col-sm-10">
                @Model.Producto.Nombre
            </dd>
            <dt class="col-sm-2">
                Fecha
            </dt>
            <dd class="col-sm-10">
                @Model.FechaTransaccion
            </dd>
            <dt class="col-sm-2">
                Cantidad
            </dt>
            <dd class="col-sm-10">
                @Model.Cantidad
            </dd>
            <dt class="col-sm-2">
                Estado
            </dt>
            <dd class="col-sm-10">
                @Model.Estado
            </dd>
        </dl>
        <form asp-action="AnularConfirmed">
            <input type="hidden" asp-for="TransaccionID" />
            <input type="submit" value="Anular" class="btn btn-danger" /> |
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
